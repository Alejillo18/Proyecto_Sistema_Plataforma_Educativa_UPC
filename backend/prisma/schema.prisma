// Configuración del generador del cliente Prisma para JavaScript/TypeScript
generator client {
  provider = "prisma-client-js"
}

// Configuración de la conexión a la base de datos de PostgreSQL sin URL para Prisma 7
datasource db {
  provider = "postgresql"
}

// Modelo que representa la tabla de usuarios
model User {
  id                  String       @id @default(uuid()) @db.Uuid
  email               String       @unique @db.VarChar(255)
  passwordHash        String       @map("password_hash") @db.VarChar(255)
  fullName            String?      @map("full_name") @db.VarChar(100)
  role                Role         @default(ESTUDIANTE)
  passwordResetToken  String?      @unique @map("password_reset_token") @db.VarChar(255)
  passwordResetExpires DateTime?   @map("password_reset_expires") @db.Timestamp(6)
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  careers             UserCareer[]

  @@map("users")
}

enum Role {
  PROFESOR
  ESTUDIANTE

  @@map("roles")
}

// Modelo que representa las carreras universitarias
model Career {
  id       String       @id @default(uuid()) @db.Uuid
  name     String       @unique @db.VarChar(150)
  subjects Subject[]
  users    UserCareer[]

  @@map("careers")
}

// Modelo que representa las materias asociadas a una carrera
model Subject {
  id           String @id @default(uuid()) @db.Uuid
  name         String @db.VarChar(150)
  yearOfCareer Int    @map("year_of_career") @db.SmallInt
  careerId     String @map("career_id") @db.Uuid
  career       Career @relation(fields: [careerId], references: [id], onDelete: Cascade)

  @@map("subjects")
}

// Tabla intermedia para gestionar la relación muchos a muchos entre usuarios y carreras
model UserCareer {
  userId   String   @map("user_id") @db.Uuid
  careerId String   @map("career_id") @db.Uuid
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  career   Career   @relation(fields: [careerId], references: [id], onDelete: Cascade)

  @@id([userId, careerId])
  @@map("user_careers")
}